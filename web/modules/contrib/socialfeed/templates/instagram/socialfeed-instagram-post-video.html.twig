{#
/**
 * @file
 * Default theme implementation to display the Instagram Video block.
 */
#}

{% set base = 'sf-instagram-post' %}
{% set classes = [base, use_instagram_style ? base ~ '--styled' : base ~ '--custom'] %}

{% if post.media_url %}
  <article class="{{ classes|join(' ') }}">
    <figure class="{{ base }}__media {{ base }}__media--video">
      {% if post.post_url %}
        <a class="{{ base }}__link" href="{{ post.post_url }}">
          <video class="{{ base }}__video" controls="controls" src="{{ post.media_url }}"></video>
        </a>
      {% else %}
        <video class="{{ base }}__video" src="{{ post.media_url }}"></video>
      {% endif %}
    </figure>
  </article>
{% endif %}
