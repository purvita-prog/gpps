{
  "name": "drupal/socialfeed",
  "type": "drupal-module",
  "description": "Provides users an option to easily fetch feeds from Facebook, Twitter, or Instagram and then display them accordingly using block.",
  "keywords": [
    "Drupal"
  ],
  "license": "GPL-2.0+",
  "homepage": "https://www.drupal.org/project/socialfeed",
  "minimum-stability": "stable",
  "support": {
    "issues": "https://www.drupal.org/project/issues/socialfeed",
    "source": "https://git.drupalcode.org/project/socialfeed"
  },
  "require": {
    "php": ">=8.2",
    "noweh/twitter-api-v2-php": "^3.7",
    "facebook/php-business-sdk": "^24.0",
    "nesbot/carbon": "^2.59 || ^3.0"
  },
  "require-dev": {
    "drupal/core-dev": "^10.3 || ^11.0"
  }
}
